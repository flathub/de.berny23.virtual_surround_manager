{
    "id": "de.berny23.virtual_surround_manager",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.10",
    "sdk": "org.kde.Sdk",
    "command": "virtual-surround-manager",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--filesystem=xdg-run/pipewire-0",
        "--talk-name=org.kde.StatusNotifierWatcher"
    ],
    "//": "The file /share/pipewire/client.conf must NOT be cleaned!",
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/etc/security",
        "/share/pipewire/filter-chain",
        "/share/pipewire/*.conf.avail",
        "/share/pipewire/filter-chain.conf",
        "/share/pipewire/jack.conf",
        "/share/pipewire/minimal.conf",
        "/share/pipewire/pipewire*.conf"
    ],
    "modules": [
        {
            "name": "virtual-surround-manager",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DIS_FLATPAK=1",
                "-DCMAKE_BUILD_TYPE=Release"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/Berny23/virtual-surround-manager.git",
                    "tag": "v1.2.1",
                    "commit": "3915a6ab4282277d7c9d0af1fdb3f6e737b6e564"
                }
            ],
            "modules": [
                {
                    "name": "pipewire",
                    "buildsystem": "meson",
                    "//": "Available options: https://gitlab.freedesktop.org/pipewire/pipewire/-/blob/master/meson_options.txt",
                    "//": "sndfile is required for reading WAV files when creating the filter chain!",
                    "config-opts": [
                        "-Dsndfile=enabled",
                        "-Dsession-managers=[]",
                        "-Dpw-cat=disabled",
                        "-Daudiotestsrc=disabled",
                        "-Dvideotestsrc=disabled",
                        "-Dvolume=disabled",
                        "-Dvulkan=disabled",
                        "-Ddocs=disabled",
                        "-Dman=disabled",
                        "-Dlibcamera=disabled",
                        "-Dlibsystemd=disabled",
                        "-Dalsa=disabled",
                        "-Dpipewire-alsa=disabled",
                        "-Djack=disabled",
                        "-Dpipewire-jack=disabled",
                        "-Dv4l2=disabled",
                        "-Dpipewire-v4l2=disabled",
                        "-Daudiomixer=disabled",
                        "-Dvideoconvert=disabled",
                        "-Dudev=disabled",
                        "-Dbluez5=disabled",
                        "-Dcontrol=disabled",
                        "-Dgstreamer=disabled",
                        "-Dgstreamer-device-provider=disabled",
                        "-Dexamples=disabled",
                        "-Dtests=disabled",
                        "-Draop=disabled",
                        "-Dsdl2=disabled",
                        "-Dlibpulse=disabled",
                        "-Droc=disabled",
                        "-Davahi=disabled",
                        "-Decho-cancel-webrtc=disabled",
                        "-Dlibusb=disabled",
                        "-Dlv2=disabled",
                        "-Dx11=disabled",
                        "-Dx11-xfixes=disabled",
                        "-Dlibcanberra=disabled",
                        "-Davb=disabled",
                        "-Dreadline=disabled",
                        "-Dgsettings=disabled",
                        "-Dcompress-offload=disabled",
                        "-Dopus=disabled",
                        "-Dlibffado=disabled",
                        "-Dsnap=disabled",
                        "-Debur128=disabled",
                        "-Dfftw=disabled",
                        "-Donnxruntime=disabled",
                        "-Drlimits-install=false",
                        "-Dlegacy-rtkit=false"
                    ],
                    "cleanup": [
                        "/bin",
                        "/include"
                    ],
                    "sources": [
                        {
                            "type": "git",
                            "url": "https://gitlab.freedesktop.org/pipewire/pipewire.git",
                            "tag": "1.6.4",
                            "commit": "3e67b89a1adb4c98c248668189f8e21c6ddc68be"
                        }
                    ]
                },
                {
                    "name": "libportal",
                    "buildsystem": "meson",
                    "//": "Available options: https://github.com/flatpak/libportal/blob/main/meson_options.txt",
                    "config-opts": [
                        "-Dbackend-qt6=enabled",
                        "-Dbackend-qt5=disabled",
                        "-Dbackend-gtk3=disabled",
                        "-Dbackend-gtk4=disabled",
                        "-Dintrospection=false",
                        "-Dvapi=false",
                        "-Ddocs=false",
                        "-Dtests=false"
                    ],
                    "sources": [
                        {
                            "type": "git",
                            "url": "https://github.com/flatpak/libportal.git",
                            "tag": "0.10.0",
                            "commit": "c23024018c8eb076549a1517fcb2d7f80d3e2ed5"
                        }
                    ]
                }
            ]
        }
    ]
}
